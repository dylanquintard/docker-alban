# Production / Dokploy
# Assumptions:
# - Public website: https://alban.flow-os.fr
# - Backend API: https://api.alban.flow-os.fr
# - Admin mobile app: https://admin.alban.flow-os.fr
# - Admin mobile V2 app: https://admin-v2.alban.flow-os.fr

# Compose / Docker
POSTGRES_DB=pizzeria
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password

# Public URLs used by browsers
PUBLIC_BACKEND_URL=https://api.alban.flow-os.fr
PUBLIC_FRONTEND_URL=https://alban.flow-os.fr
PUBLIC_ADMIN_URL=https://admin.alban.flow-os.fr
PUBLIC_ADMIN_V2_URL=https://admin-v2.alban.flow-os.fr

# Internal URL used by the frontend SEO server inside Docker
INTERNAL_API_BASE_URL=http://backend:5000/api

# Backend security and cookies
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
BACKEND_CORS_ORIGINS=https://alban.flow-os.fr,https://admin.alban.flow-os.fr,https://admin-v2.alban.flow-os.fr
TRUST_PROXY=true
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000
AUTH_COOKIE_NAME=pizzeria_auth
CSRF_COOKIE_NAME=pizzeria_csrf
CSRF_HEADER_NAME=x-csrf-token
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_MAX_AGE=604800000
ADMIN_LOGIN_MAX_FAILED_ATTEMPTS=5
ADMIN_LOGIN_LOCK_MINUTES=15
SHUTDOWN_TIMEOUT_MS=10000
UPLOAD_MAX_MB=5

# Email settings
# Fill these before production if you use registration, verification, password reset or contact emails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=change-me-smtp-password
SMTP_FROM=Pizzeria Alban <no-reply@example.com>
CONTACT_RECIPIENT_EMAIL=contact@alban.flow-os.fr
PASSWORD_RESET_URL_BASE=https://alban.flow-os.fr/reset-password
VERIFICATION_STRICT_DELIVERY=true

# Optional auth / content tuning
DEFAULT_COUNTRY_DIAL_CODE=+33
EMAIL_OTP_TTL_MINUTES=10
PASSWORD_RESET_TTL_MINUTES=30
EMAIL_OTP_DEBUG_LOGGING=false
EXPOSE_EMAIL_OTP_IN_RESPONSE=false
CONTACT_DEBUG_LOGGING=false
SITEMAP_CACHE_SECONDS=300

# Optional web push
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:contact@alban.flow-os.fr

# Print scheduler
PRINT_SCHEDULER_INTERVAL_MS=5000
PRINT_JOB_LOCK_MS=60000
PRINT_RETRY_BASE_SECONDS=5
PRINT_RETRY_MAX_SECONDS=300
PRINT_DEFAULT_MAX_ATTEMPTS=5
PRINT_AGENT_OFFLINE_AFTER_MS=30000
PRINT_JOB_RETENTION_HOURS=24
PRINT_JOB_CLEANUP_INTERVAL_MS=60000
PRINT_READY_ALERT_AFTER_MINUTES=5
PRINT_READY_FAIL_AFTER_MINUTES=10
PRINT_REPRINT_READY_FAIL_AFTER_MINUTES=10

# Optional archived/deleted user placeholder
ARCHIVED_USER_EMAIL=archived-user@local.invalid
ARCHIVED_USER_NAME=Client supprime
ARCHIVED_USER_PHONE=+33100000000

# Frontend SEO
SEO_CACHE_TTL_MS=300000
SEO_FORCE_REFRESH_MIN_INTERVAL_MS=15000
SEO_FETCH_TIMEOUT_MS=6000

# Admin PWA
VITE_SW_VERSION=

# Optional print agent profile
# Not needed for the first Dokploy deployment if the print agent stays on a Raspberry Pi later.
PRINT_AGENT_API_BASE_URL=https://api.alban.flow-os.fr
PRINT_AGENT_CODE=agent-kitchen
PRINT_AGENT_NAME=Kitchen Agent
PRINT_AGENT_TOKEN=replace-with-secure-token
PRINT_AGENT_LOCAL_ADMIN_TOKEN=change-me
PRINT_AGENT_POLL_MS=5000
PRINT_AGENT_HEARTBEAT_MS=10000
PRINT_AGENT_REQUEST_TIMEOUT_MS=10000
PRINT_AGENT_SOCKET_TIMEOUT_MS=5000
PRINT_AGENT_LOG_LEVEL=info
PRINTER_CODE=kitchen_main
PRINTER_IP=192.168.1.50
PRINTER_PORT=9100
# PRINTERS_JSON=[{"code":"kitchen_main","ip":"192.168.1.50","port":9100}]
