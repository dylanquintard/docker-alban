NODE_ENV=development

# Core runtime
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/pizzeria?schema=public
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
SHUTDOWN_TIMEOUT_MS=10000

# Public URLs and allowed origins
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
FRONTEND_SITE_URL=http://127.0.0.1:8000
UPLOAD_PUBLIC_BASE_URL=http://127.0.0.1:5000

# Reverse proxy / HTTPS
TRUST_PROXY=false
ENABLE_HSTS=false
HSTS_MAX_AGE=31536000

# Session and CSRF cookies
AUTH_COOKIE_NAME=pizzeria_auth
CSRF_COOKIE_NAME=pizzeria_csrf
CSRF_HEADER_NAME=x-csrf-token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_MAX_AGE=604800000

# Uploads
UPLOAD_DIR=./uploads
UPLOAD_MAX_MB=5

# Distributed rate limiter
RATE_LIMIT_BACKEND=auto
REDIS_URL=redis://127.0.0.1:6379

# Emails
SMTP_HOST=smtp.example.invalid
SMTP_PORT=587
SMTP_USER=no-reply@example.invalid
SMTP_PASS=replace-with-your-smtp-password
SMTP_FROM="Pizzeria <no-reply@example.invalid>"
CONTACT_RECIPIENT_EMAIL=contact@example.invalid
PASSWORD_RESET_URL_BASE=http://127.0.0.1:8000/reset-password
VERIFICATION_STRICT_DELIVERY=false

# Auth / profile behavior
DEFAULT_COUNTRY_DIAL_CODE=+33
EMAIL_OTP_TTL_MINUTES=10
PASSWORD_RESET_TTL_MINUTES=30
EMAIL_OTP_DEBUG_LOGGING=true
EXPOSE_EMAIL_OTP_IN_RESPONSE=true
CONTACT_DEBUG_LOGGING=true

# SEO / sitemap
SITEMAP_CACHE_SECONDS=300

# Web push
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@example.invalid

# Print orchestration
PRINT_SCHEDULER_ENABLED=true
PRINT_SCHEDULER_INTERVAL_MS=2000
PRINT_JOB_LOCK_MS=60000
PRINT_RETRY_BASE_SECONDS=5
PRINT_RETRY_MAX_SECONDS=300
PRINT_DEFAULT_MAX_ATTEMPTS=5
PRINT_AGENT_OFFLINE_AFTER_MS=30000
PRINT_JOB_RETENTION_HOURS=24
PRINT_JOB_CLEANUP_INTERVAL_MS=60000
PRINT_READY_ALERT_AFTER_MINUTES=5
PRINT_READY_FAIL_AFTER_MINUTES=10
PRINT_REPRINT_READY_FAIL_AFTER_MINUTES=10

# Archived/deleted user placeholder
ARCHIVED_USER_EMAIL=archived-user@local.invalid
ARCHIVED_USER_NAME=Client supprime
ARCHIVED_USER_PHONE=+33100000000
