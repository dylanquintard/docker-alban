NODE_ENV=production

# Backend API
API_BASE_URL=https://api.your-domain.tld
AGENT_CODE=agent-kitchen
AGENT_NAME=Kitchen Agent
AGENT_TOKEN=replace-with-secure-token

# Printer routing (use either PRINTERS_JSON or PRINTER_CODE/IP/PORT)
PRINTERS_JSON=[{"code":"kitchen_main","ip":"192.168.1.50","port":9100}]
# PRINTER_CODE=kitchen_main
# PRINTER_IP=192.168.1.50
# PRINTER_PORT=9100

# Runtime
POLL_MS=3000
HEARTBEAT_MS=10000
REQUEST_TIMEOUT_MS=10000
SOCKET_TIMEOUT_MS=5000
SQLITE_PATH=./data/agent.db

# Local admin HTTP endpoint
LOCAL_HTTP_HOST=127.0.0.1
LOCAL_HTTP_PORT=3000

# Required in production
LOCAL_ADMIN_TOKEN=replace-with-strong-local-token
